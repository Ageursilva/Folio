@page "/login"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies

@inject NavigationManager NavManager

<PageTitle>Login - Folio</PageTitle>

<article style="max-width: 400px; margin: auto; margin-top: 5rem;">
    <h2>Acesso Restrito</h2>

    <form method="post" @onsubmit="Logar" @formname="loginForm">
        <AntiforgeryToken />

        <label>
            Usuário
            <input type="text" name="Username" @bind="Username" required />
        </label>

        <label>
            Senha
            <input type="password" name="Password" @bind="Password" required />
        </label>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <p style="color: red;">@ErrorMessage</p>
        }

        <button type="submit">Entrar</button>
    </form>
</article>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromForm] public string Username { get; set; } = string.Empty;
    [SupplyParameterFromForm] public string Password { get; set; } = string.Empty;

    private string ErrorMessage = string.Empty;

    private async Task Logar()
    {
        if (Username == "admin" && Password == "admin")
        {
            var claims = new List<Claim> { new Claim(ClaimTypes.Name, Username) };
            var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
            var principal = new ClaimsPrincipal(identity);

            if (HttpContext != null)
            {
                await HttpContext.SignInAsync(principal);
                NavManager.NavigateTo("/admin");
            }
        }
        else
        {
            ErrorMessage = "Credenciais inválidas.";
        }
    }
}